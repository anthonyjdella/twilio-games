{
  "name": "voice-racer",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p client/tsconfig.json",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite client",
    "build": "tsc --noEmit && tsc --noEmit -p client/tsconfig.json && vite build client"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/three": "0.164.1",
    "@types/ws": "^8.5.10",
    "tsx": "^4.10.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@gltf-transform/core": "4.4.0",
    "@gltf-transform/extensions": "4.4.0",
    "three": "^0.164.0",
    "twilio": "6.0.2",
    "ws": "^8.17.0"
  }
}
